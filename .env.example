# Database (Render PostgreSQL, Neon, etc.)
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# Auth (Agent Portal + Admin Panel)
JWT_SECRET="change-me-generate-a-long-random-string"
JWT_REFRESH_SECRET="change-me-generate-a-different-long-random-string"

# Admin allow-list (Admin Panel only) — comma-separated emails
ADMIN_EMAILS="you@eastwestpk.com"

# Email (Agent Portal — OTP emails)
RESEND_API_KEY="re_xxxxxxxxxxxx"

# Cloudflare R2 (image/file storage — Agent Portal + Admin Panel)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="ewts-uploads"
R2_PUBLIC_URL=""
