// ═══════════════════════════════════════════════════════════
// EAST & WEST TRAVEL — canonical Prisma schema
// Shared by all three apps (public site, agent portal, admin panel)
// running in this one repo. Field names match the existing live
// system exactly — do not rename without updating everywhere.
// ═══════════════════════════════════════════════════════════

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── PUBLIC CONTENT ──

model Package {
  id            String   @id @default(uuid())
  category      String   // "umrah" | "tours"
  name          String
  slug          String?  @unique // for /umrah/[slug] detail pages — nullable so existing rows don't break, backfill via admin edit
  duration      String?
  price         String?  // legacy display price (listing cards) — actual bookable prices now live on PackageRoomType
  priceNote     String?  @map("price_note")
  destination   String?
  departureCity String?  @map("departure_city")
  tier          String?  // e.g. "SILVER", "GOLD", "PLATINUM" — admin free text, shown as a badge
  depDate       String?  @map("dep_date")
  retDate       String?  @map("ret_date")
  airline       String?
  route         String?
  hotels        String?
  includes      String?  // newline-separated list, rendered as a checkmark list on the detail page
  excludes      String?  // newline-separated list, rendered as an x-mark list
  // Itinerary as JSON: array of { title: string, details: string[], images?: string[] } —
  // matches the numbered step layout (Outbound Flight, Hotel in Madinah, Ziyarat, etc.)
  itinerary     Json?
  flightSectors Json?   @map("flight_sectors") // [{type:"departure"|"arrival", city, date, time}]
  imageUrl      String?  @map("image_url")
  featured      Boolean  @default(false)
  status        String   @default("active") // active | inactive
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  roomTypes     PackageRoomType[]
  bookings      Booking[]
  agentBookings AgentBooking[]

  @@map("packages")
}

// Per-package room pricing — this is what makes the detail page's "Select
// Room Type" calculator work (Quadruple/Triple/Double, each with its own
// per-person price and occupancy limits, same pattern as the reference
// site: usmantravels.com/packages/.../  — Triple/Double often require a
// minimum adult count since the room is shared).
model PackageRoomType {
  id                String  @id @default(uuid())
  packageId         String  @map("package_id")
  roomType          String  @map("room_type") // "Quadruple Room" | "Triple Room" | "Double Room" | custom
  pricePerPersonPkr Int     @map("price_per_person_pkr")
  // Fixed flat rate per infant (owner's decision: flat PKR amount, not a
  // % of adult price). Nullable/0 = free, so existing room types without
  // this set don't suddenly start charging for infants unexpectedly.
  pricePerInfantPkr Int     @default(0) @map("price_per_infant_pkr")
  pricePerChildPkr  Int     @default(0) @map("price_per_child_pkr")
  maxAdults         Int     @map("max_adults")
  maxInfants        Int     @default(0) @map("max_infants")
  minAdultsRequired Int?    @map("min_adults_required") // e.g. Triple Room needs >=3 adults booked together
  sortOrder         Int     @default(0) @map("sort_order")

  package Package @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@map("package_room_types")
}

model GroupFlight {
  id            String   @id @default(uuid())
  flightNo      String?  @map("flight_no")
  airline       String
  airlineCode   String?  @map("airline_code")
  route         String
  depDate       String?  @map("dep_date")
  arrDate       String?  @map("arr_date")
  depTime       String?  @map("dep_time")
  arrTime       String?  @map("arr_time")
  baggage       String?
  meal          String?
  region        String?  @default("international") // domestic | international | gulf | ksa
  tripType      String?  @default("oneway") @map("trip_type") // oneway | return
  price         String
  airlineLogoUrl String? @map("airline_logo_url")
  seats         Int      @default(0)
  status        String   @default("active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  agentBookings AgentBooking[]
  directBookings Booking[]

  @@map("group_flights")
}

model VisaService {
  id             String   @id @default(uuid())
  title          String
  country        String
  type           String   // tourist | umrah | business | work
  // Legacy display-only price string (e.g. "PKR 12,000") — kept so the
  // existing listing card still renders something when the new numeric
  // fields are not yet set. New code should prefer priceAdult/Child/Infant.
  price          String?
  // Age-tiered pricing (PKR, server-computed on application submission).
  // Convention: positive integer = fee. Null = not configured yet (fall
  // back to `price` string for display). Zero is a valid price (free).
  priceAdult     Int?     @map("price_adult")
  priceChild     Int?     @map("price_child")
  priceInfant    Int?     @map("price_infant")
  days           String?
  validity       String?
  maxStay        String?  @map("max_stay")
  processingTime String?  @map("processing_time")
  requirements   String?
  countryFlag    String?  @map("country_flag")
  countryImage   String?  @map("country_image")
  status         String   @default("active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  requiredDocuments VisaRequiredDocument[]
  applications      VisaApplication[]

  @@map("visa_services")
}

// Admin-configured per-visa document checklist. Each row is one document
// slot shown in the application form (e.g. "Passport Scan", "Bank Statement").
model VisaRequiredDocument {
  id          String  @id @default(uuid())
  visaId      String  @map("visa_id")
  name        String                      // e.g. "Passport Scan"
  description String?                     // instruction shown to user
  isRequired  Boolean @default(true) @map("is_required")
  sortOrder   Int     @default(0)  @map("sort_order")

  visa      VisaService               @relation(fields: [visaId], references: [id], onDelete: Cascade)
  uploads   VisaApplicationDocument[]

  @@map("visa_required_documents")
}

// One application row per visa per batch. Multiple rows can share a
// batchRef (same family/submission session). Status is tracked per-row so
// a family can be approved for one country and rejected for another.
// Convention: totalPricePkr is always positive (cost to applicant).
model VisaApplication {
  id             String   @id @default(uuid())
  // Groups submissions made together in one session. NOT a FK — just a
  // shared string so admin can see "these 3 came in together."
  batchRef       String   @map("batch_ref")
  visaId         String   @map("visa_id")
  // Applicant contact (the lead person submitting, not per-traveler)
  fullName       String   @map("full_name")
  passportNumber String   @map("passport_number")
  phone          String
  email          String
  // Traveler counts for this specific visa application
  adults         Int      @default(1)
  children       Int      @default(0)
  infants        Int      @default(0)
  // Server-computed at submission: adults×priceAdult + children×priceChild
  // + infants×priceInfant. Stored so price is auditable even if admin
  // later changes the visa price.
  totalPricePkr  Int      @map("total_price_pkr")
  // Pipeline: pending → under_review → approved | rejected | more_info_needed
  status         String   @default("pending")
  adminNote      String?  @map("admin_note")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  visa      VisaService             @relation(fields: [visaId], references: [id])
  documents VisaApplicationDocument[]

  @@map("visa_applications")
}

// One row per uploaded document per application. docId links back to the
// VisaRequiredDocument that defined this slot (can be null if applicant
// uploads an extra/ad-hoc file not tied to a specific requirement).
model VisaApplicationDocument {
  id        String   @id @default(uuid())
  appId     String   @map("app_id")
  docId     String?  @map("doc_id")   // nullable: extra uploads not tied to a slot
  fileUrl   String   @map("file_url")
  fileName  String   @map("file_name")
  createdAt DateTime @default(now()) @map("created_at")

  application VisaApplication       @relation(fields: [appId], references: [id], onDelete: Cascade)
  document    VisaRequiredDocument? @relation(fields: [docId], references: [id], onDelete: SetNull)

  @@map("visa_application_documents")
}


model InsuranceCompany {
  id          String   @id @default(uuid())
  name        String
  logoUrl     String?  @map("logo_url")
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  plans InsurancePlan[]

  @@map("insurance_companies")
}

model InsurancePlan {
  id          String   @id @default(uuid())
  companyId   String   @map("company_id")
  name        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  company InsuranceCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)
  rates   InsuranceRate[]

  @@map("insurance_plans")
}

model InsuranceRate {
  id              String   @id @default(uuid())
  planId          String   @map("plan_id")
  pricePkr        Int      @map("price_pkr")
  coverageDetails String?  @map("coverage_details")
  // Added so the public /insurance quote calculator can actually filter
  // by destination/duration instead of just listing everything by price.
  // destination: a region/country string, e.g. "Worldwide", "Schengen",
  // "USA/Canada", "Asia" — kept as free text (admin-entered) rather than a
  // fixed enum, since insurance companies define their own region buckets.
  // durationDays: the trip length this specific rate covers, e.g. 7, 15,
  // 30, 90 — the calculator matches the closest rate >= requested duration.
  destination     String?
  durationDays    Int?     @map("duration_days")
  createdAt       DateTime @default(now()) @map("created_at")

  plan InsurancePlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@map("insurance_rates")
}

model Blog {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  category    String?
  coverImage  String?  @map("cover_image")
  excerpt     String?
  content     String?
  published   Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("blogs")
}

// ── DIRECT (WALK-IN) BOOKINGS ──

model Booking {
  id           String   @id @default(uuid())
  bookingRef   String   @unique @map("booking_ref")
  customerName String?  @map("customer_name")
  phone        String?
  email        String?
  service      String?
  // Package-booking specific fields — null for other booking types (visa,
  // group ticket direct bookings, etc. that also use this table).
  packageId       String? @map("package_id")
  roomTypeLabel   String? @map("room_type_label") // snapshot of the room type name at booking time (e.g. "Triple Room") — don't rely on live PackageRoomType, admin might change/delete it later
  // Direct (non-agent) group flight booking — sibling to packageId above.
  // A Booking row is either a package booking (packageId set) or a group
  // flight booking (groupFlightId set), never both. Kept on the same
  // table rather than a new one since it's the same "direct customer
  // booking" concept the admin Direct Bookings module already lists.
  groupFlightId   String? @map("group_flight_id")
  travelClass     String? @map("travel_class") // "Economy" | "Business" | "First Class" — group flight bookings only
  seatsRequested  Int?    @map("seats_requested") // group flight bookings only; package bookings use adults/children/infants instead
  adults          Int?    @default(1)
  children        Int?    @default(0)
  infants         Int?    @default(0)
  passport        String? // CNIC/Passport, optional, useful for travel docs
  specialRequests String? @map("special_requests")
  totalPricePkr   Int?    @map("total_price_pkr") // snapshot of the computed total at booking time, same immutability reasoning as agent commission — price display can change later, this booking's price shouldn't retroactively
  status       String   @default("pending") // pending | confirmed | cancelled — payment status is a SEPARATE concern, added later per the owner's own pipeline plan
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  travellers Traveller[]
  package    Package?    @relation(fields: [packageId], references: [id])
  groupFlight GroupFlight? @relation(fields: [groupFlightId], references: [id])

  @@map("bookings")
}

model Traveller {
  id         String  @id @default(uuid())
  bookingId  String  @map("booking_id")
  fullName   String  @map("full_name")
  passportNo String? @map("passport_no")
  cnic       String?

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("travellers")
}

// ── AGENTS ──

// Per-agent, per-service-type commission rate, set by admin. One row per
// (agent, serviceType) — updating it is an upsert, so admin can change an
// agent's rate any time (e.g. relationship improves, target hit). This
// table is only ever the CURRENT rate — see AgentBooking.commission below
// for why past bookings are unaffected by rate changes.
model AgentCommissionRate {
  id          String   @id @default(uuid())
  agentId     String   @map("agent_id")
  serviceType String   @map("service_type") // "umrah" | "group_ticket" | "insurance"
  rateType    String   @map("rate_type")    // "fixed" (flat PKR amount) | "percentage" (of sell_price)
  value       Int      // fixed: PKR amount, e.g. 2000 or 15000. percentage: whole number, e.g. 30 for 30%
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  agent Agent @relation(fields: [agentId], references: [id])

  @@unique([agentId, serviceType])
  @@map("agent_commission_rates")
}

model Agent {
  id           String   @id @default(uuid())
  agentCode    String   @unique @map("agent_code")
  fullName     String   @map("full_name")
  email        String   @unique
  phone        String?
  passwordHash String   @map("password_hash")
  balance      Int      @default(0)      // in PKR — admin-write-only
  creditLimit  Int      @default(0) @map("credit_limit") // admin-write-only
  tier         String   @default("standard") // admin-write-only
  status       String   @default("active")   // active | suspended
  logoUrl      String?  @map("logo_url")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  bookings        AgentBooking[]
  commissionRates AgentCommissionRate[]
  transactions AgentTransaction[]
  otps         AgentOtp[]
  paymentSlips PaymentSlip[]

  @@map("agents")
}

model AgentBooking {
  id                String    @id @default(uuid())
  agentId           String    @map("agent_id")
  serviceType       String    @map("service_type") // "umrah" | "group_ticket" | "insurance" — exact strings, do not rename
  groupFlightId     String?   @map("group_flight_id")
  // Which SPECIFIC package/tour this booking is for (umrah/tours bookings
  // only — group_ticket bookings use groupFlightId instead, insurance
  // bookings reference neither). Without this, admin could only filter by
  // broad category, so opening one specific tour showed every booking in
  // that category regardless of which actual package it was for.
  packageId         String?   @map("package_id")
  status            String    @default("pending") // pending | confirmed | issue_requested | issued | cancelled
  sellPrice         Int       @map("sell_price")
  // Snapshot of the agent's commission rate AT THE TIME this booking was
  // created (computed via lib/commission.ts from AgentCommissionRate).
  // Deliberately NOT recalculated later — if admin changes the agent's
  // rate afterward, only future bookings use the new rate; this row keeps
  // whatever was correct when it was made.
  commission        Int       @default(0)
  bookingRef        String    @unique @map("booking_ref")
  expiresAt         DateTime? @map("expires_at")
  issueRequestedAt  DateTime? @map("issue_requested_at")
  issueRequestedBy  String?   @map("issue_requested_by")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  agent       Agent        @relation(fields: [agentId], references: [id])
  groupFlight GroupFlight? @relation(fields: [groupFlightId], references: [id])
  package     Package?     @relation(fields: [packageId], references: [id])

  @@map("agent_bookings")
}

model AgentTransaction {
  id        String   @id @default(uuid())
  agentId   String   @map("agent_id")
  amount    Int
  type      String   // debit | credit
  note      String?
  createdAt DateTime @default(now()) @map("created_at")

  agent Agent @relation(fields: [agentId], references: [id])

  @@map("agent_transactions")
}

// Backend-only table. No client (public/agent/admin frontend) queries this
// directly — only the OTP request/verify API routes touch it, using the
// database connection on the server. See security notes in the agent
// portal brief: OTP codes are generated + verified entirely server-side.
model AgentOtp {
  id        String   @id @default(uuid())
  agentId   String   @map("agent_id")
  otpCode   String   @map("otp_code")
  purpose   String   // "issue_request" | "password_reset"
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  attempts  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  agent Agent @relation(fields: [agentId], references: [id])

  @@map("agent_otps")
}

model PaymentSlip {
  id           String   @id @default(uuid())
  agentId      String   @map("agent_id")
  amount       Int
  slipImageUrl String?  @map("slip_image_url")
  status       String   @default("pending") // pending | approved | rejected
  note         String?
  createdAt    DateTime @default(now()) @map("created_at")

  agent Agent @relation(fields: [agentId], references: [id])

  @@map("payment_slips")
}

// Admin-configured bank accounts shown to agents on the Topup page.
model BankAccount {
  id            String   @id @default(uuid())
  bankName      String   @map("bank_name")
  logoUrl       String?  @map("logo_url")
  accountTitle  String   @map("account_title")
  accountNumber String   @map("account_number")
  iban          String?
  branchCode    String?  @map("branch_code")
  sortOrder     Int      @default(0) @map("sort_order")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("bank_accounts")
}

// ── ADMIN USERS ──
// Separate from Agent — admins are internal staff, gated additionally by
// the ADMIN_EMAILS allow-list at the application layer (see admin panel
// brief's security section), not just by having a row in this table.

model AdminUser {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  fullName     String?  @map("full_name")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("admin_users")
}
